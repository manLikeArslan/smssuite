# Database (SQLite by default)
DATABASE_URL="file:./dev.db"

# App password for login (change this!)
APP_PASSWORD="your-secure-password"

# Pushcut webhook URL for sending SMS via iOS Shortcuts
# Get this from https://www.pushcut.io
PUSHCUT_WEBHOOK_URL="https://api.pushcut.io/v1/webhook/YOUR_WEBHOOK_ID"
