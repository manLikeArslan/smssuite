generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model List {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())
  contacts  Contact[]
  sessions  CampaignSession[]
}

model Contact {
  id          String   @id @default(cuid())
  phone       String
  status      String?
  step        Int      @default(0)
  lastSent    String?
  blacklisted String?
  list        List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId      String
}

model Stats {
  id           Int @id @default(1)
  totalSent    Int @default(0)
  coldOutreach Int @default(0)
  followUps    Int @default(0)
  errors       Int @default(0)
}

model CampaignSession {
  id             String        @id @default(cuid())
  mode           String        // "cold" or "followup"
  status         String        @default("running") // "running", "paused", "completed", "error"
  totalTargets   Int           @default(0)
  processedCount Int           @default(0)
  isDryRun       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  listId         String
  list           List          @relation(fields: [listId], references: [id], onDelete: Cascade)
  logs           CampaignLog[]
}

model CampaignLog {
  id         String          @id @default(cuid())
  sessionId  String
  session    CampaignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  time       String
  message    String
  type       String          @default("info") // "info", "success", "error", "warning"
  duration   Int?            // Optional duration for progress bar in ms
  createdAt  DateTime        @default(now())
}
